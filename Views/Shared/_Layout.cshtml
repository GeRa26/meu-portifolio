<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfólio de Desenvolvedor ASP.NET Core MVC" />
    <title>@ViewData["Title"] - Portfólio</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
</head>
<body>
    <header>
        <nav class="container" style="display: flex; justify-content: space-between; align-items: center; position: relative;">
            <a class="logo" asp-area="" asp-controller="Home" asp-action="Index" style="z-index: 1000;">Portfólio.</a>
            <div class="mobile-menu-toggle" id="mobile-menu">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </div>
            <ul class="nav-links">
                <li><a href="#about">@ViewBag.UI["NavAbout"]</a></li>
                <li><a href="#experience">@ViewBag.UI["NavExperience"]</a></li>
                <li><a href="#projects">@ViewBag.UI["NavProjects"]</a></li>
                <li><a href="#skills">@ViewBag.UI["NavSkills"]</a></li>
                <li><a href="#contact">@ViewBag.UI["NavContact"]</a></li>
                <li style="display: flex; gap: 10px; margin-left: 10px; align-items: center;">
                    @{
                        var targetLang = ViewBag.Lang == "en" ? "pt" : "en";
                        var currentLangLabel = ViewBag.Lang == "en" ? "EN" : "PT";
                    }
                    <a href="?lang=@targetLang" title="Mudar Idioma" class="header-action-btn">
                        @currentLangLabel
                    </a>
                    <button id="theme-toggle" title="Alternar Modo Escuro/Claro" class="header-action-btn">
                        ☀️
                    </button>
                </li>
            </ul>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <p>&copy; @DateTime.Now.Year - @ViewBag.UI["FooterText"]</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
